From 4ff2d1ac74304a3684d6c381ed93c9070a0f3944 Mon Sep 17 00:00:00 2001
From: Monutchee Systems <engineering@monutchee.com>
Date: Fri, 12 Jun 2026 23:55:00 -0400
Subject: [PATCH] cmake: use system Glaze package

Yocto builds run without network access after do_fetch. Consume the Glaze
package staged by the glaze recipe instead of downloading it with FetchContent.

Upstream-Status: Pending
Signed-off-by: Monutchee Systems <engineering@monutchee.com>
---
 CMakeLists.txt | 12 +-----------
 1 file changed, 1 insertion(+), 11 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index d31d5d9..5cc37e9 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -13,17 +13,7 @@ file(CREATE_LINK
 find_package(Boost 1.74 REQUIRED)
 find_package(OpenSSL REQUIRED)
 find_package(Threads REQUIRED)
-
-# glaze — header-only JSON (de)serialisation. Fetched at configure time; needs
-# network access on the first configure (then cached under the build tree).
-include(FetchContent)
-FetchContent_Declare(
-    glaze
-    GIT_REPOSITORY https://github.com/stephenberry/glaze.git
-    GIT_TAG        v7.7.1
-    GIT_SHALLOW    TRUE
-)
-FetchContent_MakeAvailable(glaze)
+find_package(glaze 7.7.1 CONFIG REQUIRED)
 
 # ── The reusable web-engine library ───────────────────────────────────────────
 add_library(webengine STATIC
-- 
2.43.0
